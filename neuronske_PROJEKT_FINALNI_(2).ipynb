        "---\n",
        "## 13. Konvolucijski Autoenkoder \n",
        "\n",
        "**Autoenkoder** je neuronska mreza koja uci komprimirati podatke u latentni prostor i rekonstruirati ih.\n",
        "\n",
        "### Arhitektura:\n",
        "- **Enkoder:** Conv2D(32) → MaxPool → Conv2D(16) → MaxPool → Conv2D(8) → MaxPool\n",
        "  - Komprimira sliku 48x48 (2304 piksela) u latentni vektor 6x6x8 (288 vrijednosti)\n",
        "  - Kompresija: **8x**\n",
        "- **Dekoder:** Conv2D(8) → UpSample → Conv2D(16) → UpSample → Conv2D(32) → UpSample → Conv2D(1)\n",
        "  - Rekonstruira originalnu sliku iz latentnog prostora\n",
        "\n",
        "### Cilj:\n",
        "- Demonstracija ucenja latentnih reprezentacija\n",
        "- Vizualizacija kvalitete rekonstrukcije\n",
        "- Pokazuje da model moze nauciti kompaktnu reprezentaciju slika lica"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 14,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "I3c1y8XmRfNP",
        "outputId": "d1e6eef2-fb82-4fe8-874c-55f68bd0f7b1"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Autoenkoder ucitan s Drive-a — preskacemo treniranje!\n"
          ]
        }
      ],
      "source": [
        "def build_autoencoder():\n",
        "    input_img = tf.keras.layers.Input(shape=(48, 48, 1), name='INPUT')\n",
        "\n",
        "    # ENKODER\n",
        "    x = tf.keras.layers.Conv2D(32, (3,3), activation='relu', padding='same')(input_img)\n",
        "    x = tf.keras.layers.MaxPooling2D((2,2), padding='same')(x)\n",
        "    x = tf.keras.layers.Conv2D(16, (3,3), activation='relu', padding='same')(x)\n",
        "    x = tf.keras.layers.MaxPooling2D((2,2), padding='same')(x)\n",
        "    x = tf.keras.layers.Conv2D(8,  (3,3), activation='relu', padding='same')(x)\n",
        "    encoded = tf.keras.layers.MaxPooling2D((2,2), padding='same', name='LATENT')(x)\n",
        "\n",
        "    # DEKODER\n",
        "    x = tf.keras.layers.Conv2D(8,  (3,3), activation='relu', padding='same')(encoded)\n",
        "    x = tf.keras.layers.UpSampling2D((2,2))(x)\n",
        "    x = tf.keras.layers.Conv2D(16, (3,3), activation='relu', padding='same')(x)\n",
        "    x = tf.keras.layers.UpSampling2D((2,2))(x)\n",
        "    x = tf.keras.layers.Conv2D(32, (3,3), activation='relu', padding='same')(x)\n",
        "    x = tf.keras.layers.UpSampling2D((2,2))(x)\n",
        "    decoded = tf.keras.layers.Conv2D(1, (3,3), activation='sigmoid', padding='same', name='OUTPUT')(x)\n",
        "\n",
        "    return tf.keras.Model(input_img, decoded, name='ConvAutoencoder')\n",
        "\n",
        "AE_PATH = '/content/drive/MyDrive/conv_ae.keras'\n",
        "\n",
        "if os.path.exists(AE_PATH):\n",
        "    conv_ae = tf.keras.models.load_model(AE_PATH)\n",
        "    print('Autoenkoder ucitan s Drive-a — preskacemo treniranje!')\n",
        "else:\n",
        "    conv_ae = build_autoencoder()\n",
        "    conv_ae.compile(optimizer='adam', loss='mse')\n",
        "    conv_ae.summary()\n",
        "\n",
        "    # Za autoenkoder, input = output\n",
        "    train_ae = train_ds.map(lambda x, y: (x, x))\n",
        "    val_ae   = val_ds.map(lambda x, y: (x, x))\n",
        "\n",
        "    history_ae = conv_ae.fit(\n",
        "        train_ae, validation_data=val_ae, epochs=30,\n",
        "        callbacks=[tf.keras.callbacks.EarlyStopping(\n",
        "            monitor='val_loss', patience=5, restore_best_weights=True\n",
        "        )]\n",
        "    )\n",
        "\n",
        "    conv_ae.save(AE_PATH)\n",
        "    print('Autoenkoder istreniran i spremljen na Drive!')"
      ]
    },
