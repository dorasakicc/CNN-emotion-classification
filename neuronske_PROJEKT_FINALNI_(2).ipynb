      "source": [
        "---\n",
        "## 4. Priprema podataka\n",
        "\n",
        "### Augmentacija podataka \n",
        "Koristimo augmentaciju za umjetno povecanje raznolikosti trening skupa:\n",
        "- **RandomFlip** — horizontalno zrcaljenje (lice je simetricno)\n",
        "- **RandomRotation** — mala rotacija do 10 stupnjeva\n",
        "- **RandomZoom** — malo zumiranje\n",
        "- **RandomContrast** — promjena kontrasta\n",
        "\n",
        "### Class Weights\n",
        "Rjesavamo problem neuravnotezenih klasa tako da model daje vecu tezinu manjinskim klasama.\n",
        "Npr. disgust (436 slika) dobiva tezinu 9.4, dok happy (7215 slika) dobiva tezinu 0.57.\n",
        "Na taj nacin model ne ignorira rijetke klase.\n",
        "\n",
        "### Normalizacija\n",
        "Skaliramo piksele iz raspona [0, 255] u [0, 1] jer neuronske mreze bolje uce s manjim vrijednostima."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "cL6Ms8ksRfNL",
        "outputId": "f8e2f8d0-73ad-4de4-9a9b-4564d8a26a97"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Found 28709 files belonging to 7 classes.\n",
            "Using 22968 files for training.\n",
            "Found 28709 files belonging to 7 classes.\n",
            "Using 5741 files for validation.\n",
            "Found 7178 files belonging to 7 classes.\n",
            "Klase: ['angry', 'disgust', 'fear', 'happy', 'neutral', 'sad', 'surprise']\n",
            "\n",
            "Class weights:\n",
            "  angry: 1.027\n",
            "  disgust: 9.407\n",
            "  fear: 1.001\n",
            "  happy: 0.568\n",
            "  neutral: 0.826\n",
            "  sad: 0.849\n",
            "  surprise: 1.293\n",
            "\n",
            "Train: 359 batcheva\n",
            "Val:   90 batcheva\n",
            "Test:  113 batcheva\n"
          ]
        }
      ],
      "source": [
        "IMG_SIZE   = 48\n",
        "BATCH_SIZE = 64\n",
        "SEED       = 42\n",
        "AUTOTUNE   = tf.data.AUTOTUNE\n",
        "\n",
        "train_ds_raw = tf.keras.utils.image_dataset_from_directory(\n",
        "    TRAIN_PATH, image_size=(IMG_SIZE, IMG_SIZE), batch_size=BATCH_SIZE,\n",
        "    color_mode='grayscale', seed=SEED, validation_split=0.2, subset='training'\n",
        ")\n",
        "val_ds_raw = tf.keras.utils.image_dataset_from_directory(\n",
        "    TRAIN_PATH, image_size=(IMG_SIZE, IMG_SIZE), batch_size=BATCH_SIZE,\n",
        "    color_mode='grayscale', seed=SEED, validation_split=0.2, subset='validation'\n",
        ")\n",
        "test_ds_raw = tf.keras.utils.image_dataset_from_directory(\n",
        "    TEST_PATH, image_size=(IMG_SIZE, IMG_SIZE), batch_size=BATCH_SIZE, color_mode='grayscale'\n",
        ")\n",
        "\n",
        "CLASS_NAMES = train_ds_raw.class_names\n",
        "NUM_CLASSES = len(CLASS_NAMES)\n",
        "print('Klase:', CLASS_NAMES)\n",
        "\n",
        "# Augmentacija \n",
        "augment = tf.keras.Sequential([\n",
        "    tf.keras.layers.RandomFlip('horizontal'),\n",
        "    tf.keras.layers.RandomRotation(0.1),\n",
        "    tf.keras.layers.RandomZoom(0.1),\n",
        "    tf.keras.layers.RandomContrast(0.1),\n",
        "])\n",
        "\n",
        "def pripremi_dataset(ds, augmentacija=False):\n",
        "    ds = ds.map(lambda x, y: (x / 255.0, y), num_parallel_calls=AUTOTUNE)\n",
        "    if augmentacija:\n",
        "        ds = ds.map(lambda x, y: (augment(x, training=True), y), num_parallel_calls=AUTOTUNE)\n",
        "    return ds.cache().prefetch(AUTOTUNE)\n",
        "\n",
        "train_ds = pripremi_dataset(train_ds_raw, augmentacija=True)\n",
        "val_ds   = pripremi_dataset(val_ds_raw)\n",
        "test_ds  = pripremi_dataset(test_ds_raw)\n",
        "\n",
        "# Class weights za neuravnotezene klase\n",
        "total = sum(counts.values())\n",
        "class_weight = {}\n",
        "for i, klasa in enumerate(CLASS_NAMES):\n",
        "    n = counts.get(klasa, 1)\n",
        "    class_weight[i] = total / (NUM_CLASSES * n)\n",
        "\n",
        "print('\\nClass weights:')\n",
        "for i, klasa in enumerate(CLASS_NAMES):\n",
        "    print(f'  {klasa}: {class_weight[i]:.3f}')\n",
        "\n",
        "print(f'\\nTrain: {len(list(train_ds_raw))} batcheva')\n",
        "print(f'Val:   {len(list(val_ds_raw))} batcheva')\n",
        "print(f'Test:  {len(list(test_ds_raw))} batcheva')"
      ]
    },
