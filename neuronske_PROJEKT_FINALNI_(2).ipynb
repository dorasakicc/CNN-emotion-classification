        "---\n",
        "## 6. Transfer Learning — MobileNetV2 \n",
        "\n",
        "**Transfer Learning** je tehnika gdje koristimo model pretreniran na velikom datasetu\n",
        "(ImageNet — 1.2 milijuna slika, 1000 klasa) i prilagodavamo ga nasem problemu.\n",
          
        "\n",
        "### Zasto MobileNetV2?\n",
        "- Lagan model dizajniran za mobilne uredaje\n",
        "- Koristi depthwise separable konvolucije — manje parametara\n",
        "- Pretreniran na ImageNet datasetu\n",
        "\n",
        "### Prilagodbe:\n",
        "- FER2013 slike su 48x48 grayscale — resizamo na 96x96 RGB jer MobileNet zahtijeva veci input\n",
        "- Zamrzavamo pretreniranim tezinama i treniramo samo klasifikacijske slojeve\n",
        "\n",
        "### Hipoteza:\n",
        "Transfer learning bi trebao dati bolje rezultate jer koristi znanje nauceno na milijunima slika.\n",
        "Testiramo ovu hipotezu i uspredujemo s CNN-om od nule."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "fyRfHYzRRfNM",
        "outputId": "16bb84da-1b1d-4c09-a9eb-9ceb3ddc2d68"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Found 28709 files belonging to 7 classes.\n",
            "Using 22968 files for training.\n",
            "Found 28709 files belonging to 7 classes.\n",
            "Using 5741 files for validation.\n",
            "Found 7178 files belonging to 7 classes.\n",
            "Transfer Learning ucitan s Drive-a — preskacemo treniranje!\n",
            "Transfer Learning accuracy: 42.39%\n"
          ]
        }
      ],
      "source": [
        "# Priprema dataseta u RGB formatu i 96x96 za MobileNet\n",
        "train_ds_96 = tf.keras.utils.image_dataset_from_directory(\n",
        "    TRAIN_PATH, image_size=(96,96), batch_size=64,\n",
        "    color_mode='rgb', seed=SEED, validation_split=0.2, subset='training'\n",
        ")\n",
        "val_ds_96 = tf.keras.utils.image_dataset_from_directory(\n",
        "    TRAIN_PATH, image_size=(96,96), batch_size=64,\n",
        "    color_mode='rgb', seed=SEED, validation_split=0.2, subset='validation'\n",
        ")\n",
        "test_ds_96 = tf.keras.utils.image_dataset_from_directory(\n",
        "    TEST_PATH, image_size=(96,96), batch_size=64, color_mode='rgb'\n",
        ")\n",
        "\n",
        "def pripremi_96(ds, augmentacija=False):\n",
        "    ds = ds.map(lambda x, y: (x / 255.0, y), num_parallel_calls=AUTOTUNE)\n",
        "    if augmentacija:\n",
        "        aug = tf.keras.Sequential([\n",
        "            tf.keras.layers.RandomFlip('horizontal'),\n",
        "            tf.keras.layers.RandomRotation(0.1),\n",
        "            tf.keras.layers.RandomZoom(0.1),\n",
        "        ])\n",
        "        ds = ds.map(lambda x, y: (aug(x, training=True), y), num_parallel_calls=AUTOTUNE)\n",
        "    return ds.cache().prefetch(AUTOTUNE)\n",
        "\n",
        "train_ds_96 = pripremi_96(train_ds_96, augmentacija=True)\n",
        "val_ds_96   = pripremi_96(val_ds_96)\n",
        "test_ds_96  = pripremi_96(test_ds_96)\n",
        "\n",
        "TL_PATH = '/content/drive/MyDrive/model_tl.keras'\n",
        "\n",
        "if os.path.exists(TL_PATH):\n",
        "    model_tl = tf.keras.models.load_model(TL_PATH)\n",
        "    print('Transfer Learning ucitan s Drive-a — preskacemo treniranje!')\n",
        "else:\n",
        "    base_model = tf.keras.applications.MobileNetV2(\n",
        "        input_shape=(96,96,3), include_top=False, weights='imagenet'\n",
        "    )\n",
        "    base_model.trainable = False\n",
        "\n",
        "    inputs  = tf.keras.Input(shape=(96,96,3))\n",
        "    x       = base_model(inputs, training=False)\n",
        "    x       = tf.keras.layers.GlobalAveragePooling2D()(x)\n",
        "    x       = tf.keras.layers.Dense(256, activation='relu')(x)\n",
        "    x       = tf.keras.layers.Dropout(0.5)(x)\n",
        "    outputs = tf.keras.layers.Dense(NUM_CLASSES, activation='softmax')(x)\n",
        "\n",
        "    model_tl = tf.keras.Model(inputs, outputs)\n",
        "    model_tl.compile(\n",
        "        optimizer=tf.keras.optimizers.Adam(0.001),\n",
        "        loss='sparse_categorical_crossentropy',\n",
        "        metrics=['accuracy']\n",
        "    )\n",
        "\n",
        "    history_tl = model_tl.fit(\n",
        "        train_ds_96, validation_data=val_ds_96,\n",
        "        epochs=20,\n",
        "        callbacks=[\n",
        "            tf.keras.callbacks.EarlyStopping(\n",
        "                monitor='val_accuracy', patience=5, restore_best_weights=True\n",
        "            )\n",
        "        ],\n",
        "        class_weight=class_weight\n",
        "    )\n",
        "\n",
        "    model_tl.save(TL_PATH)\n",
        "    print('Transfer Learning istreniran i spremljen na Drive!')\n",
        "\n",
        "test_loss_tl, test_acc_tl = model_tl.evaluate(test_ds_96, verbose=0)\n",
        "print(f'Transfer Learning accuracy: {test_acc_tl*100:.2f}%')"
      ]
    },
