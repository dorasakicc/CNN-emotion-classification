        "---\n",
        "## 14. Grad-CAM vizualizacija\n",
        "\n",
        "**Grad-CAM** (Gradient-weighted Class Activation Mapping) vizualizira\n",
        "koja podrucja slike CNN smatra najvaznijima za klasifikaciju.\n",
        "\n",
        "### Kako radi:\n",
        "1. Racunamo gradijente izlaza modela s obzirom na zadnji konvolucijski sloj\n",
        "2. Tezinski usrednjimo aktivacijske mape po kanalima\n",
        "3. Rezultat je heatmapa koja pokazuje \"vazna\" podrucja\n",
        "\n",
        "### Sto ocekujemo:\n",
        "- Za **happy**: fokus na usta (osmijeh)\n",
        "- Za **surprise**: fokus na oci i usta (otvoreni)\n",
        "- Za **angry**: fokus na obrve i celo (nabrane)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 17,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 632
        },
        "id": "vQ9mZNl2RfNP",
        "outputId": "03ae1ad8-2917-4bfc-8603-9c7c12ec4e40"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stderr",
          "text": [
            "WARNING:matplotlib.image:Clipping input data to the valid range for imshow with RGB data ([0..1] for floats or [0..255] for integers). Got range [0.0..1.0000000238418578].\n"
          ]
        },
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 2000x900 with 21 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ],
      "source": [
        "def make_gradcam_heatmap(img_array, model):\n",
        "    model.build((None, 48, 48, 1))\n",
        "    _ = model(img_array, training=False)\n",
        "\n",
        "    # Dinamicki pronadi zadnji conv sloj\n",
        "    last_conv_name = [l.name for l in model.layers if 'conv2d' in l.name][-1]\n",
        "    last_conv_layer = model.get_layer(last_conv_name)\n",
        "\n",
        "    submodel = tf.keras.Sequential(model.layers[:model.layers.index(last_conv_layer)+1])\n",
        "    submodel.build((None, 48, 48, 1))\n",
        "\n",
        "    with tf.GradientTape() as tape:\n",
        "        conv_outputs = submodel(img_array, training=False)\n",
        "        tape.watch(conv_outputs)\n",
        "        x = conv_outputs\n",
        "        for layer in model.layers[model.layers.index(last_conv_layer)+1:]:\n",
        "            x = layer(x, training=False)\n",
        "        predictions = x\n",
        "        pred_index = tf.argmax(predictions[0])\n",
        "        class_channel = predictions[:, pred_index]\n",
        "\n",
        "    grads = tape.gradient(class_channel, conv_outputs)\n",
        "    pooled_grads = tf.reduce_mean(grads, axis=(0, 1, 2))\n",
        "    heatmap = conv_outputs[0] @ pooled_grads[..., tf.newaxis]\n",
        "    heatmap = tf.squeeze(heatmap)\n",
        "    heatmap = tf.maximum(heatmap, 0) / (tf.math.reduce_max(heatmap) + 1e-8)\n",
        "    return heatmap.numpy(), predictions.numpy()\n",
        "\n",
        "# Uzmi po jednu sliku po emociji\n",
        "uzorak_slike, uzorak_labele = [], []\n",
        "for slike, labele in test_ds:\n",
        "    for s, l in zip(slike, labele):\n",
        "        if l.numpy() not in uzorak_labele:\n",
        "            uzorak_slike.append(s)\n",
        "            uzorak_labele.append(l.numpy())\n",
        "        if len(uzorak_labele) == NUM_CLASSES:\n",
        "            break\n",
        "    if len(uzorak_labele) == NUM_CLASSES:\n",
        "        break\n",
        "\n",
        "fig, axes = plt.subplots(3, NUM_CLASSES, figsize=(20, 9))\n",
        "fig.suptitle('Grad-CAM — Sto CNN gleda po emociji', fontsize=14)\n",
        "\n",
        "for i, (slika, labela) in enumerate(zip(uzorak_slike, uzorak_labele)):\n",
        "    img_array = tf.expand_dims(slika, 0)\n",
        "    heatmap, preds = make_gradcam_heatmap(img_array, model_cnn)\n",
        "    pred_klasa = CLASS_NAMES[np.argmax(preds)]\n",
        "\n",
        "    axes[0,i].imshow(slika.numpy().squeeze(), cmap='gray')\n",
        "    axes[0,i].set_title(f'Stvarno: {CLASS_NAMES[labela]}', fontsize=8)\n",
        "    axes[0,i].axis('off')\n",
        "\n",
        "    axes[1,i].imshow(heatmap, cmap='jet')\n",
        "    axes[1,i].set_title('Grad-CAM', fontsize=8)\n",
        "    axes[1,i].axis('off')\n",
        "\n",
        "    slika_rgb = np.stack([slika.numpy().squeeze()]*3, axis=-1)\n",
        "    heatmap_r = tf.image.resize(heatmap[..., tf.newaxis], (48,48)).numpy().squeeze()\n",
        "    overlay = 0.6 * slika_rgb + 0.4 * cm.jet(heatmap_r)[:,:,:3]\n",
        "    axes[2,i].imshow(overlay)\n",
        "    axes[2,i].set_title(f'Predvideno: {pred_klasa}', fontsize=8)\n",
        "    axes[2,i].axis('off')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
