        "fig.suptitle('Feature Visualization — Filtri prvog Conv sloja (32 filtera)', fontsize=14)\n",
        "\n",
        "for i, ax in enumerate(axes.flat):\n",
        "    if i < weights.shape[3]:\n",
        "        f = weights[:, :, 0, i]\n",
        "        f = (f - f.min()) / (f.max() - f.min())\n",
        "        ax.imshow(f, cmap='viridis')\n",
        "        ax.set_title(f'Filter {i+1}', fontsize=7)\n",
        "    ax.axis('off')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
